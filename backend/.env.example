# ════════════════════════════════════════════════════════════════════════════════
# Backend Environment Variables (.env.example)
# Copy this file to .env and fill in with your actual values
# For production on Render, set these in the Dashboard instead of in .env file
# ════════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Example MongoDB Atlas URI: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
DB_NAME=airo_db

# ──────────────────────────────────────────────────────────────────────────────
# Authentication & Security
# ──────────────────────────────────────────────────────────────────────────────
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGO=HS256

# ──────────────────────────────────────────────────────────────────────────────
# AI & LLM Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Groq API Key: Get from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key

# ──────────────────────────────────────────────────────────────────────────────
# GitHub Integration (Optional)
# ──────────────────────────────────────────────────────────────────────────────
# GitHub Personal Access Token: https://github.com/settings/tokens
GITHUB_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Email Configuration
# ──────────────────────────────────────────────────────────────────────────────
# For Gmail: Use App Passwords (https://myaccount.google.com/apppasswords)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@airo.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM_NAME=AIRO Support

# ──────────────────────────────────────────────────────────────────────────────
# Frontend Configuration (for CORS in production)
# ──────────────────────────────────────────────────────────────────────────────
# Example: https://airo-frontend-xxx.onrender.com
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Application Environment
# ──────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=True

# ──────────────────────────────────────────────────────────────────────────────
# Logging (Optional)
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
